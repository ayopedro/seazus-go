{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "railpack",
    "buildCommand": "mkdir -p bin && go build -ldflags=\"-s -w\" -o bin/seazus-api ./cmd/api"
  },
  "deploy": {
    "startCommand": "bin/seazus-api",
    "healthcheckPath": "/",
    "restartPolicyType": "on-failure"
  }
}